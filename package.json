{
  "name": "safe-stake",
  "version": "0.1.0",
  "description": "Independent non-custodial staking UI for Safenet Beta. Track A operator submission by Denna Labs.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/crampeddamselfly/safe-stake"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "svelte-kit sync && vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && eslint .",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "verify:merkle": "tsx scripts/verify-merkle.ts",
    "pin:ipfs": "tsx scripts/pin-to-ipfs.ts"
  },
  "dependencies": {
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@lucide/svelte": "^1.16.0",
    "@reown/appkit": "^1.6.0",
    "@reown/appkit-adapter-wagmi": "^1.6.0",
    "@safe-global/safe-apps-sdk": "^9.1.0",
    "@tanstack/svelte-query": "^5.59.0",
    "@wagmi/connectors": "^5.7.0",
    "@wagmi/core": "^2.16.0",
    "bits-ui": "^1.0.0",
    "clsx": "^2.1.1",
    "lucide-svelte": "^1.0.1",
    "mode-watcher": "^1.1.0",
    "svelte-sonner": "^1.1.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "viem": "^2.46.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.8.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.0.0-beta.7",
    "@types/node": "^22.10.0",
    "ajv": "^8.17.0",
    "ajv-cli": "^5.0.0",
    "ajv-formats": "^3.0.1",
    "axe-core": "^4.10.0",
    "eslint": "^9.16.0",
    "eslint-plugin-svelte": "^2.46.0",
    "globals": "^15.13.0",
    "prettier": "^3.4.0",
    "prettier-plugin-svelte": "^3.3.0",
    "svelte": "^5.2.0",
    "svelte-check": "^4.1.0",
    "tailwindcss": "^4.0.0-beta.7",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.16.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.1"
  }
}

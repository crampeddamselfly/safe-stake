# Required: WalletConnect/Reown project id — get free at https://cloud.reown.com
VITE_REOWN_PROJECT_ID=

# Optional per-chain RPC overrides (if absent, viem default RPCs are used)
VITE_RPC_URL_1=
VITE_RPC_URL_11155111=

# Optional: default chain id on first load (1 = mainnet, 11155111 = sepolia)
VITE_DEFAULT_CHAIN_ID=1

# Optional: site origin used for Safe App manifest and OG tags
VITE_SITE_ORIGIN=https://safestake.denna.eth.limo
